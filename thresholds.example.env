# Baseline-multiplier thresholds.
# A response is SUSPICIOUS if it exceeds (multiplier × baseline mean) OR the absolute cap.
export WALLT0R_LATENCY_MULTIPLIER=3
export WALLT0R_BYTES_MULTIPLIER=3

# Absolute hard caps — trigger SUSPICIOUS regardless of baseline.
export WALLT0R_ABSOLUTE_MAX_LATENCY_SECONDS=120
export WALLT0R_ABSOLUTE_MAX_BYTES=100000

# Hard curl timeout per request. Responses that exceed this are LOOK_HERE.
# Keep this above WALLT0R_ABSOLUTE_MAX_LATENCY_SECONDS so slow-but-responding
# requests are captured as SUSPICIOUS with data rather than dropped as LOOK_HERE.
export WALLT0R_REQUEST_TIMEOUT_SECONDS=60

# Token and tool-call absolute limits (provider-reported values).
export WALLT0R_MAX_TOKENS=2000
export WALLT0R_MAX_TOOL_CALLS=5

# Seconds to wait between attack requests.
# export WALLT0R_SLEEP_SECONDS=5
