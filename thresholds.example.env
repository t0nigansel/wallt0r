export WALLT0R_MAX_RESPONSE_BYTES=10000
# Flag a response as SUSPICIOUS if latency exceeds this value.
export WALLT0R_MAX_LATENCY_SECONDS=20
export WALLT0R_MAX_TOKENS=2000
export WALLT0R_MAX_TOOL_CALLS=5

# Hard curl timeout per request. If the server does not respond within this
# time the result is recorded as TIMEOUT. Keep this well above
# WALLT0R_MAX_LATENCY_SECONDS so slow-but-responding requests are captured
# as SUSPICIOUS with full data rather than dropped as TIMEOUT.
export WALLT0R_REQUEST_TIMEOUT_SECONDS=60

# Seconds to wait between attack requests. Gives the server time to recover
# from a previous attack before the next prompt is sent. Set to 0 to disable.
# export WALLT0R_SLEEP_SECONDS=5
